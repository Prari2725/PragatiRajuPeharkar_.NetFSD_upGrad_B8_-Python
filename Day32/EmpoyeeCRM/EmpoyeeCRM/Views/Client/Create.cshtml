@model EmpoyeeCRM.Models.Client

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow p-4">

                <h2 class="text-center mb-4">Create Client</h2>

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- Client Name -->
                    <div class="mb-3">
                        <label asp-for="ClientName" class="form-label"></label>
                        <input asp-for="ClientName" class="form-control" placeholder="Enter client name" />
                        <span asp-validation-for="ClientName" class="text-danger"></span>
                    </div>

                    <!-- Project Name -->
                    <div class="mb-3">
                        <label asp-for="ProjectName" class="form-label"></label>
                        <input asp-for="ProjectName" class="form-control" placeholder="Enter project name" />
                        <span asp-validation-for="ProjectName" class="text-danger"></span>
                    </div>

                    <!-- Project Value -->
                    <div class="mb-3">
                        <label asp-for="ProjectValue" class="form-label"></label>
                        <input asp-for="ProjectValue" class="form-control" placeholder="Enter value" />
                        <span asp-validation-for="ProjectValue" class="text-danger"></span>
                    </div>

                    <!-- Employee Dropdown -->
                    <div class="mb-3">
                        <label asp-for="EmployeeId" class="form-label">Assign Employee</label>
                        <select asp-for="EmployeeId" asp-items="ViewBag.Employees" class="form-select">
                            <option value="">-- Select Employee --</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>

                    <!-- Button -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg">
                            Save Client
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}