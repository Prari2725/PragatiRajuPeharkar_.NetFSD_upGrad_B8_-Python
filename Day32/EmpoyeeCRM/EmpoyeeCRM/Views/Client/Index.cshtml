@model IEnumerable<EmpoyeeCRM.Models.Client>

<div class="container mt-5">
    <div class="card shadow p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Clients</h2>
            <a asp-action="Create" class="btn btn-success">+ Add Client</a>
        </div>

        <table class="table table-bordered table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Client Name</th>
                    <th>Project</th>
                    <th>Project Value</th>
                    <th>Employee</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ClientName</td>
                            <td>@item.ProjectName</td>
                            <td>₹@item.ProjectValue</td>
                            <td>@(item.Employee != null ? item.Employee.Name : "Not Assigned")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-info btn-sm me-1">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-warning btn-sm me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ClientId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this client?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No clients found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>